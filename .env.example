# ---- Build-time (baked into the web bundle) ----
# Public base path the frontend calls; nginx proxies this prefix to the backend.
EXPO_PUBLIC_API_URL=/api

# ---- Run-time (read by nginx in the container) ----
# Where /api/* requests are proxied to (the PHP backend, no trailing slash).
BACKEND_URL=https://endpoint.daythree.ai/faithMobile/routes

# ---- Local deployment ----
# Host port to expose the app on (http://localhost:PORT).
PORT=8080
